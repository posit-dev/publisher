{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2023",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "lib": ["ES2023", "DOM"],
    "paths": {
      "vscode": ["./src/mocks/vscode.ts"],
      "positron": ["./src/mocks/positron.ts"],
      "src/*": ["../../extensions/vscode/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
