{
  "extends": [
    "@tsconfig/node22/tsconfig.json",
    "@vue/tsconfig/tsconfig.dom.json"
  ],
  "include": ["src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "@publisher/core": ["../../../../packages/core/src/index.ts"]
    },
    "verbatimModuleSyntax": false,
    "types": ["@types/vscode-webview", "@types/node"]
  }
}
